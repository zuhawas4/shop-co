# Copy to backend/.env — never commit real secrets

PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/shopco?retryWrites=true&w=majority
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
# Comma-separated frontend origins allowed in production (optional; cors is open by default)
# CLIENT_URL=https://your-frontend.vercel.app
